@model EdVerse.ViewModels.Academic.Course.CourseEditVm

@{
    ViewData["Title"] = "Edit Course";
}

<h2>Edit Course</h2>

<form asp-action="Edit" method="post">

    <input asp-for="Id" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="CourseCode" class="form-label"></label>
        <input asp-for="CourseCode" class="form-control" />
        <span asp-validation-for="CourseCode" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CourseName" class="form-label"></label>
        <input asp-for="CourseName" class="form-control" />
        <span asp-validation-for="CourseName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DurationInYears" class="form-label"></label>
        <input asp-for="DurationInYears" class="form-control" />
        <span asp-validation-for="DurationInYears" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TotalSemesters" class="form-label"></label>
        <input asp-for="TotalSemesters" class="form-control" />
        <span asp-validation-for="TotalSemesters" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">
        Update
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Back
    </a>

</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
